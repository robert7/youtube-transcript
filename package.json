{
  "name": "@danielxceron/youtube-transcript",
  "version": "1.2.6",
  "description": "Fetch transcript from a youtube video",
  "main": "dist/youtube-transcript.common.js",
  "browser": "dist/youtube-transcript.esm.js",
  "module": "dist/youtube-transcript.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/youtube-transcript.esm.js",
      "require": "./dist/youtube-transcript.common.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "youtube-transcript": "./cli.js"
  },
  "scripts": {
    "build": "rollup -c",
    "cli": "node cli.js"
  },
  "author": "Daniel Ceron Claros <danielxceron>",
  "contributors": [
    "Kakulukian (Original author)"
  ],
  "keywords": [
    "youtube",
    "transcript"
  ],
  "license": "MIT",
  "devDependencies": {
    "rollup": "^2.28.2",
    "rollup-plugin-typescript": "^1.0.1",
    "rollup-plugin-typescript2": "^0.27.3",
    "tslib": "^2.0.1",
    "typescript": "^4.0.3"
  },
  "files": [
    "dist/*",
    "cli.js"
  ],
  "repository": "https://github.com/danielxceron/youtube-transcript.git",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/danielxceron/youtube-transcript",
  "engines": {
    "node": ">=18.0.0"
  }
}
